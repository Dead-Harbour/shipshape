{
    "author": "ChrisOfNormandy",
    "description": "Common helper functions and configs.",
    "license": "MIT",
    "name": "@dead-harbour/shipshape",
    "packageManager": "yarn@4.16.0",
    "type": "module",
    "version": "1.0.0",
    "files": [
        "dist"
    ],
    "exports": {
        "./eslint": {
            "types": "./dist/lib/eslint.d.ts",
            "import": "./dist/lib/eslint.js",
            "require": null
        },
        "./numbers": {
            "types": "./dist/lib/numbers.d.ts",
            "import": "./dist/lib/numbers.js",
            "require": null
        },
        "./props": {
            "types": "./dist/lib/props.d.ts",
            "import": "./dist/lib/props.js",
            "require": null
        },
        "./sorting": {
            "types": "./dist/lib/sorting.d.ts",
            "import": "./dist/lib/sorting.js",
            "require": null
        },
        "./strings": {
            "types": "./dist/lib/strings.d.ts",
            "import": "./dist/lib/strings.js",
            "require": null
        },
        "./stylelint": {
            "types": "./dist/lib/stylelint.d.ts",
            "import": "./dist/lib/stylelint.js",
            "require": null
        }
    },
    "dependencies": {
        "@eslint-react/eslint-plugin": "^5.8.11",
        "@eslint/config-helpers": "^0.6.0",
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@stylistic/stylelint-config": "^5.0.0",
        "@stylistic/stylelint-plugin": "^5.2.0",
        "stylelint": "^17.12.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-scss": "^7.2.0",
        "typescript-eslint": "^8.60.1"
    },
    "devDependencies": {
        "@types/node": "^25.9.2",
        "eslint": "^10.4.1",
        "knip": "^6.15.0",
        "postcss": "^8.5.15",
        "tsc-alias": "^1.8.17",
        "typescript": "^6.0.3"
    },
    "scripts": {
        "build": "yarn clean; tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
        "clean": "rm -rf dist",
        "lint": "eslint . --fix",
        "sanity": "yarn typecheck && yarn lint && yarn knip",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    }
}
