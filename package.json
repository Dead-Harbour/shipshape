{
    "author": "ChrisOfNormandy",
    "description": "Common helper functions and configs.",
    "license": "MIT",
    "name": "@dead-harbour/shipshape",
    "packageManager": "yarn@4.17.1",
    "type": "module",
    "version": "1.0.4",
    "files": [
        "dist"
    ],
    "exports": {
        "./oxlint": {
            "types": "./dist/lib/oxlint.d.ts",
            "import": "./dist/lib/oxlint.js",
            "require": null
        },
        "./numbers": {
            "types": "./dist/lib/numbers.d.ts",
            "import": "./dist/lib/numbers.js",
            "require": null
        },
        "./props": {
            "types": "./dist/lib/props.d.ts",
            "import": "./dist/lib/props.js",
            "require": null
        },
        "./sorting": {
            "types": "./dist/lib/sorting.d.ts",
            "import": "./dist/lib/sorting.js",
            "require": null
        },
        "./strings": {
            "types": "./dist/lib/strings.d.ts",
            "import": "./dist/lib/strings.js",
            "require": null
        },
        "./stylelint": {
            "types": "./dist/lib/stylelint.d.ts",
            "import": "./dist/lib/stylelint.js",
            "require": null
        }
    },
    "dependencies": {
        "@stylistic/stylelint-config": "^5.0.0",
        "@stylistic/stylelint-plugin": "^5.2.1",
        "oxlint-tsgolint": "^7.0.2001",
        "stylelint": "^17.14.1",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-scss": "^7.2.0"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "knip": "^6.29.0",
        "oxlint": "^1.75.0",
        "postcss": "^8.5.22",
        "tsc-alias": "^1.9.1",
        "typescript": "^7.0.2"
    },
    "scripts": {
        "build": "yarn clean; tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
        "clean": "rm -rf dist",
        "lint": "oxlint . --fix && yarn lint:scss",
        "lint:scss": "yarn stylelint '**/*.scss' --fix",
        "sanity": "yarn typecheck && yarn lint && yarn knip",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    }
}